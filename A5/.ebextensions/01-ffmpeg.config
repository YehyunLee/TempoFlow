# System packages for librosa/soundfile and video tooling (best-effort; AL2023 package names may vary).
commands:
  01_install_media_packages:
    command: |
      if command -v dnf >/dev/null 2>&1; then
        dnf install -y ffmpeg libsndfile || dnf install -y ffmpeg-free libsndfile || true
      elif command -v yum >/dev/null 2>&1; then
        yum install -y ffmpeg libsndfile || true
      fi
