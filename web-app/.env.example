# TempoFlow web app environment modes
# Default for development: keep everything local and avoid AWS.

# Storage mode:
# - local: save uploaded videos only on this device
# - aws: save locally and upload to S3
NEXT_PUBLIC_APP_STORAGE_MODE=local

# Analysis mode:
# - local: browser pose analysis + local coaching text
# - api: browser pose analysis + hosted AI coaching summary
NEXT_PUBLIC_APP_ANALYSIS_MODE=local

# Optional hosted coaching API configuration
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Local EBS processing service for /analysis session view
# Start with:
#   cd "A2/pipelines/Audio data processing"
#   uvicorn ebs_fastapi_server:app --host 127.0.0.1 --port 8787
#
# Python-only (set in the shell before uvicorn, not in this file):
#   EBS_AUTO_ALIGN_MODE=chroma_sw   # default — chroma + local match (A5-style)
#   EBS_AUTO_ALIGN_MODE=onset_xcorr # legacy global lag alignment
# Speed tuning (chroma path only; lower cost ≈ coarser time grid):
#   EBS_CHROMA_HOP=1024            # default; try 2048 for faster, 512 for max quality
#   EBS_ALIGN_CHROMA_SR=11025      # optional: align chroma at 11kHz (faster); omit = full 22050
# Beat / segmentation (shared-window librosa work — often the main cost after extract):
#   EBS_BEAT_TRACK_SR=11025        # default — ~2× less audio than 22050; use 22050 for max quality
#
# FFmpeg on PATH is used by default (macOS/Linux Homebrew, Windows if installer adds PATH).
# If ffmpeg/ffprobe are not found (common on Windows), set full paths before uvicorn:
#   EBS_FFMPEG_PATH=C:\ffmpeg\bin\ffmpeg.exe
#   EBS_FFPROBE_PATH=C:\ffmpeg\bin\ffprobe.exe

# Do this by running:
# set EBS_FFMPEG_PATH=C:\ffmpeg\bin\ffmpeg.exe
# set EBS_FFPROBE_PATH=C:\ffmpeg\bin\ffprobe.exe

#   # macOS/Linux example:
#   # EBS_FFMPEG_PATH=/opt/homebrew/bin/ffmpeg
#   # EBS_FFPROBE_PATH=/opt/homebrew/bin/ffprobe
EBS_PROCESSOR_URL=http://127.0.0.1:8787/api/process
NEXT_PUBLIC_EBS_PROCESSOR_URL=http://127.0.0.1:8787/api/process

# SAM 3 via Roboflow (per-frame live) + WebRTC video-file processing
SAM3_BACKEND=roboflow
ROBOFLOW_API_KEY=

# WebRTC video-file processing (SAM 3 "Generate overlays" button).
# 1. Go to app.roboflow.com and fork the SAM 3 template workflow:
#    https://docs.roboflow.com/changelog/explore-by-month/november-2025/create-a-sam-3-api-with-roboflow-workflows
# 2. Copy your workspace slug and the workflow ID from the URL, e.g.:
#    https://app.roboflow.com/my-workspace/workflows/sam-3-workflow
ROBOFLOW_WORKSPACE_NAME=
ROBOFLOW_WORKFLOW_ID=
# GPU plan — webrtc-gpu-large is required for SAM 3 (expect ~5 FPS)
ROBOFLOW_WEBRTC_PLAN=webrtc-gpu-large
ROBOFLOW_WEBRTC_REGION=us

SAM3_PROMPT=person
SAM3_REFERENCE_PROMPT=
SAM3_PRACTICE_PROMPT=
SAM3_MAX_VIDEO_MB=40

# Only needed later when AWS upload mode is enabled
AWS_REGION=us-east-1
USER_VIDEO_BUCKET_NAME=your-user-video-bucket-name
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
